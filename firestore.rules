rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null
        && get(/databases/$(database)/documents/falleros/$(request.auth.uid)).data.rol == 'admin';
    }
    function isDirectiva() {
      return request.auth != null
        && get(/databases/$(database)/documents/falleros/$(request.auth.uid)).data.rol == 'directiva';
    }
    function isPrivileged() { return isAdmin() || isDirectiva(); }

    // Falleros: cada fallero lee/actualiza su propio perfil; admins y directiva leen todos
    match /falleros/{userId} {
      allow read: if request.auth != null
        && (request.auth.uid == userId || isPrivileged());
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null
        && (request.auth.uid == userId || isAdmin());
    }

    // Anuncios: cualquier fallero autenticado lee; admins y directiva escriben
    match /anuncios/{docId} {
      allow read:  if request.auth != null;
      allow write: if isPrivileged();
    }

    // Eventos: cualquier fallero autenticado lee; admins y directiva escriben
    match /eventos/{docId} {
      allow read:  if request.auth != null;
      allow write: if isPrivileged();
    }

    // Inscripciones: fallero autenticado crea la suya y borra/edita las suyas; admins gestionan todo
    match /inscripciones/{docId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid;
      allow update, delete: if request.auth != null
        && (resource.data.uid == request.auth.uid || isPrivileged());
    }
  }
}
